{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",

  "permission": {
    "*": "ask",
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "brew *": "deny",
      "sudo *": "deny",
      "gh *": "allow",
      "head *": "allow",
      "git *": "allow",
    },
  },
}
