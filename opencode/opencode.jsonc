{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",

  "agent": {
    "build": {
      "model": "opencode-go/deepseek-v4-flash",
    },
    "plan": {
      "model": "opencode-go/kimi-k2.6",
    },
  },

  "permission": {
    // allow to use standard tools
    "*": "allow",

    // git operations
    "bash": {
      // ask before any command not specified below
      "*": "ask",

      // do not install or run scripts with admin privileges
      "brew *": "deny",
      "sudo *": "deny",

      // deny file-reading/searching operations that have internal tool equivalents
      "cat": "deny",
      "cat *": "deny",
      "ls": "deny",
      "ls *": "deny",
      "grep": "deny",
      "grep *": "deny",
      "head *": "deny",
      "tail *": "deny",

      // allow git operations
      "git *": "allow",

      // allow to create or manage pull requests
      "gh pr *": "allow",
    },
  },
}
