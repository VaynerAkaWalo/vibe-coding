{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",

  "permission": {
    // allow to use standard tools
    "*": "allow",

    // git operations
    "bash": {
      // ask before any command not specified below
      "*": "ask",

      // do not install or run scripts with admin privileges
      "brew *": "deny",
      "sudo *": "deny",

      // allow git operations
      "git *": "allow",

      // allow to create or manage pull requests
      "gh pr *": "allow",

      // allow to `run` or `test` projects with makefile
      "make run *": "allow",
      "make test *": "allow",
    },
  },
}
